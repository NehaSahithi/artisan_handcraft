# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database Configuration (MongoDB Atlas/Local)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/karigar?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your_jwt_secret_should_be_at_least_32_characters_long
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Razorpay Payments (Test Keys)
RAZORPAY_KEY_ID=rzp_test_change_this_to_your_key_id
RAZORPAY_KEY_SECRET=change_this_to_your_key_secret
RAZORPAY_WEBHOOK_SECRET=change_this_to_your_webhook_secret

# Cloudinary Storage
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Nodemailer SMTP Configuration
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
FROM_EMAIL=noreply@karigar.in
FROM_NAME=Karigar Handicrafts

# Field-Level Encryption Key (32-character Hex String)
# Must be exactly 32 bytes (64 hex characters or 32 chars) for AES-256
ENCRYPTION_KEY=1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p
